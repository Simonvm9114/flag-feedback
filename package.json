{
  "name": "flag-feedback",
  "version": "2.0.0",
  "description": "Framework-agnostic client library for structured, element-level feedback",
  "type": "module",
  "main": "./dist/flag-feedback.umd.js",
  "module": "./dist/flag-feedback.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/flag-feedback.esm.js",
      "require": "./dist/flag-feedback.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint src dev",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:connectors": "node scripts/validate-connectors.mjs"
  },
  "keywords": [
    "feedback",
    "user-feedback",
    "dom"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simonvm9114/flag-feedback.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.0.10",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "eslint-plugin-import-x": "^4.16.1",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.14"
  }
}
