{
  "name": "flag-feedback",
  "version": "1.1.0",
  "description": "Framework-agnostic vanilla JS Web Component for collecting structured user feedback",
  "type": "module",
  "main": "./dist/flag-feedback.umd.js",
  "module": "./dist/flag-feedback.esm.js",
  "exports": {
    ".": {
      "import": "./dist/flag-feedback.esm.js",
      "require": "./dist/flag-feedback.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint src"
  },
  "keywords": [
    "feedback",
    "web-component",
    "custom-element",
    "screenshot",
    "interaction-recording"
  ],
  "dependencies": {
    "html2canvas": "^1.4.1",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "vite": "^7.3.1"
  }
}
